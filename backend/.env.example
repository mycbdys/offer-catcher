# DeepSeek API Key (获取地址: https://platform.deepseek.com/api_keys)
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx

# 可选: 自定义 LLM 配置
# LLM_BASE_URL=https://api.deepseek.com/v1
